{
  "manifest_version": 3,
  "name": "Tab Harbor",
  "version": "0.1.3",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "permissions": [
    "sidePanel",
    "tabs",
    "tabGroups",
    "storage",
    "favicon"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+H" },
      "description": "__MSG_cmdOpenPanel__"
    },
    "next-space": {
      "suggested_key": { "default": "Alt+Shift+Period" },
      "description": "__MSG_cmdNextSpace__"
    },
    "prev-space": {
      "suggested_key": { "default": "Alt+Shift+Comma" },
      "description": "__MSG_cmdPrevSpace__"
    }
  }
}
